---
import { Image } from 'astro:assets'

export interface Props {
  href: string
  thumbnail: string
  alt: string
  company: string
  title: string
  description: string
}

const { href, thumbnail, alt, company, title, description } =
  Astro.props
---

<a href={href} class="group block bg-white rounded-xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
  <!-- Thumbnail -->
  <div class="bg-noto-bg-alt">
    <Image
      src={thumbnail}
      alt={alt}
      width={600}
      height={340}
      loading="lazy"
      class="w-full h-auto block"
    />
  </div>

  <!-- Content -->
  <div class="p-6">
    <span class="text-[0.6875rem] text-noto-text-muted tracking-wide mb-2 block">
      {company}
    </span>
    <h3 class="font-serif text-xl font-medium mb-3 leading-snug transition-colors duration-300 group-hover:text-noto-accent">
      {title}
    </h3>
    <p class="text-sm text-noto-text-muted leading-relaxed">
      {description}
    </p>
    <span class="inline-flex items-center gap-2 mt-4 text-xs text-noto-accent font-medium transition-[gap] duration-200 group-hover:gap-3">
      詳細を見る
      <span class="transition-transform duration-200 group-hover:translate-x-0.5">→</span>
    </span>
  </div>
</a>
