---
import { getTopArticles } from '@/lib/microcms/api/articles'
import { formatDate } from '@/utils/format'

export interface Props {
  class?: string
}

const { class: className } = Astro.props

const { contents } = await getTopArticles({ limit: 4 })

const articles = contents.map((article) => ({
  id: article.id,
  title: article.title,
  excerpt: article.description,
  thumbnail: article.thumbnail,
  category: article.category,
  date: formatDate(article.date),
  href: article.zennUrl,
  isExternal: true,
}))
---

<section
  id="articles"
  class:list={['py-28 px-6 md:px-12', className]}
  style="background: linear-gradient(180deg, #f5f5f5 0%, #fafafa 100%);"
>
  <div class="section-header flex justify-between items-end mb-16 pb-6 border-b border-noto-border max-w-[900px] mx-auto">
    <h2 class="font-serif text-[clamp(1.75rem,4vw,2.5rem)] font-normal tracking-tight">執筆</h2>
    <span class="text-[0.6875rem] text-noto-accent tracking-[0.15em] font-medium">ARTICLES</span>
  </div>

  <div class="flex flex-col gap-6 max-w-[900px] mx-auto">
    {articles.map((article) => (
      <a
        href={article.href}
        target={article.isExternal ? '_blank' : undefined}
        rel={article.isExternal ? 'noopener noreferrer' : undefined}
        class="group grid grid-cols-1 sm:grid-cols-[160px_1fr] md:grid-cols-[220px_1fr] items-center gap-4 md:gap-6 p-5 md:p-6 bg-white rounded-md border border-noto-border shadow-sm no-underline text-inherit transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 hover:border-noto-accent"
      >
        <div class="rounded bg-neutral-100 shrink-0">
          <img
            src={`${article.thumbnail.url}?fm=webp&w=360`}
            alt={article.title}
            class="w-full h-auto block rounded"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-[0.6875rem] text-noto-text-muted tracking-wide">{article.date}</span>
            <span class="text-[0.625rem] text-noto-accent tracking-wide px-2 py-0.5 bg-noto-accent/10 rounded font-medium">
              {article.category}
            </span>
          </div>
          <h3 class="font-serif text-[1.0625rem] font-medium leading-normal mb-2 transition-colors duration-200 group-hover:text-noto-accent">
            {article.title}
          </h3>
          <p class="text-[0.8125rem] text-noto-text-muted leading-relaxed mb-4">
            {article.excerpt}
          </p>
          <span class="inline-flex items-center gap-2 text-xs text-noto-accent font-medium transition-[gap] duration-200 group-hover:gap-3 after:content-['→'] after:transition-transform after:duration-200 group-hover:after:translate-x-0.5">
            続きを読む
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="text-center mt-10">
    <a
      href="/articles"
      class="inline-flex items-center gap-2 px-8 py-3 text-[0.8125rem] text-noto-accent no-underline border border-noto-border rounded transition-all duration-200 hover:border-noto-accent hover:bg-noto-accent/5"
    >
      もっと見る →
    </a>
  </div>
</section>
