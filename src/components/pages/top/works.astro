---
import { Image } from 'astro:assets'
import { getTopWorks } from '@/lib/microcms/api/works'

export interface Props {
  class?: string
}

const { class: className } = Astro.props

const { contents } = await getTopWorks({ limit: 4 })

const works = contents.map((work) => ({
  id: work.id,
  title: work.title,
  description: work.description,
  company: work.company,
  image: work.thumbnail.url,
  href: `/works/${work.id}`,
}))
---

<section
  id="works"
  class:list={['py-28 px-6 md:px-12', className]}
  style="background: linear-gradient(180deg, white 0%, #f8f9fa 100%);"
>
  <div class="section-header flex justify-between items-end mb-16 pb-6 border-b border-noto-border max-w-[900px] mx-auto">
    <h2 class="font-serif text-[clamp(1.75rem,4vw,2.5rem)] font-normal tracking-tight">実績</h2>
    <span class="text-[0.6875rem] text-noto-accent tracking-[0.15em] font-medium">WORKS</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[900px] mx-auto">
    {works.map((work) => (
      <a
        href={work.href}
        class="group block no-underline text-inherit bg-white rounded-xl overflow-hidden shadow-sm transition-all duration-300 hover:shadow-md hover:-translate-y-0.5"
      >
        <div class="bg-[#e8e8e8]">
          <Image
            src={work.image}
            alt={work.title}
            width={600}
            height={340}
            loading="lazy"
            class="w-full h-auto block"
          />
        </div>
        <div class="p-6">
          <span class="text-[0.6875rem] text-noto-text-muted tracking-wide mb-2 block">
            {work.company}
          </span>
          <h3 class="font-serif text-lg font-medium mb-2.5 leading-snug transition-colors duration-300 group-hover:text-noto-accent">
            {work.title}
          </h3>
          <p class="text-[0.8125rem] text-noto-text-muted leading-relaxed">
            {work.description}
          </p>
          <span class="inline-flex items-center gap-2 mt-4 text-xs text-noto-accent font-medium transition-[gap] duration-200 group-hover:gap-3 after:content-['→'] after:transition-transform after:duration-200 group-hover:after:translate-x-0.5">
            詳細を見る
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="relative mt-10 max-w-[900px] mx-auto">
    <span class="absolute right-0 -top-6 text-[0.6875rem] text-noto-text-muted">※ 参画した開発プロジェクトを掲載しています</span>
    <div class="text-center">
      <a
        href="/works"
        class="inline-flex items-center gap-2 px-8 py-3 text-[0.8125rem] text-noto-accent no-underline border border-noto-border rounded transition-all duration-200 hover:border-noto-accent hover:bg-noto-accent/5"
      >
        もっと見る →
      </a>
    </div>
  </div>
</section>
