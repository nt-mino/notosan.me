---
export interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div class:list={['min-h-screen relative overflow-hidden bg-noto-bg', className]}>
  <!-- Background Orbs -->
  <div class="absolute inset-0 overflow-hidden z-0">
    <div
      class="absolute w-[500px] h-[500px] rounded-full opacity-60 -top-[100px] -right-[50px] blur-[40px]"
      style="background: radial-gradient(circle at 30% 30%, rgba(120, 150, 180, 0.6) 0%, rgba(61, 90, 128, 0.4) 40%, rgba(61, 90, 128, 0.1) 70%, transparent 100%); animation: float1 12s ease-in-out infinite;"
    />
    <div
      class="absolute w-[380px] h-[380px] rounded-full opacity-60 bottom-[50px] right-[12%] blur-[30px]"
      style="background: radial-gradient(circle at 35% 35%, rgba(140, 170, 200, 0.5) 0%, rgba(90, 127, 168, 0.35) 40%, rgba(61, 90, 128, 0.1) 70%, transparent 100%); animation: float2 10s ease-in-out infinite;"
    />
    <div
      class="absolute w-[280px] h-[280px] rounded-full opacity-60 top-[30%] right-[3%] blur-[25px]"
      style="background: radial-gradient(circle at 40% 30%, rgba(160, 185, 210, 0.45) 0%, rgba(90, 127, 168, 0.3) 40%, rgba(61, 90, 128, 0.08) 70%, transparent 100%); animation: float3 14s ease-in-out infinite;"
    />
  </div>

  <!-- Hero Content -->
  <section class="min-h-screen flex flex-col justify-center px-6 py-32 md:px-12 md:py-24 relative z-10 max-w-[900px] mx-auto">
    <div class="text-[0.75rem] text-noto-text-muted tracking-[0.2em] mb-8 flex items-center gap-4">
      <span class="w-8 h-px bg-noto-border" />
      ソフトウェアエンジニア
    </div>

    <h1
      class="font-serif text-[clamp(2.25rem,5vw,3.25rem)] font-medium leading-[1.4] tracking-[0.02em] mb-8 max-w-[700px] opacity-0"
      style="animation: fadeUp 0.8s ease forwards 0.1s;"
    >
      技術の力で<br /><span class="text-noto-accent">体験</span>を届ける
    </h1>

    <p
      class="text-base text-noto-text-muted max-w-[540px] mb-12 leading-8 opacity-0"
      style="animation: fadeUp 0.8s ease forwards 0.2s;"
    >
      「なぜつくるのか」を大切に、本当に必要とされるものをつくる。<br />
      一人でも多くの人に届けるために、今日もコードを書いています。
    </p>

    <div
      class="flex flex-col sm:flex-row gap-4 items-start opacity-0"
      style="animation: fadeUp 0.8s ease forwards 0.3s;"
    >
      <a
        href="#works"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-noto-text text-noto-bg text-[0.8125rem] font-medium no-underline rounded-sm tracking-[0.03em] transition-all duration-300 hover:bg-noto-accent"
      >
        実績を見る
      </a>
      <a
        href="#articles"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-transparent text-noto-text text-[0.8125rem] font-medium no-underline border border-noto-border rounded-sm tracking-[0.03em] transition-all duration-300 hover:border-noto-text"
      >
        記事を読む
      </a>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-6 md:left-12 flex-col items-center gap-3 text-[0.6875rem] text-noto-text-muted tracking-[0.15em] hidden md:flex">
      <div class="flex flex-col items-center gap-1">
        <span
          class="block w-2.5 h-2.5 border-r-[1.5px] border-b-[1.5px] border-noto-accent"
          style="animation: scrollArrow 2s ease-in-out infinite;"
        />
        <span
          class="block w-2.5 h-2.5 border-r-[1.5px] border-b-[1.5px] border-noto-accent opacity-60"
          style="animation: scrollArrow2 2s ease-in-out infinite 0.15s;"
        />
        <span
          class="block w-2.5 h-2.5 border-r-[1.5px] border-b-[1.5px] border-noto-accent opacity-30"
          style="animation: scrollArrow3 2s ease-in-out infinite 0.3s;"
        />
      </div>
      SCROLL
    </div>
  </section>
</div>
