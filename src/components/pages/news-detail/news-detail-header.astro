---
import type { MicroCMSImage } from '@/lib/microcms/types/common'

export interface Props {
  date: string
  category: string
  badgeType: 'release' | 'event' | 'media' | 'award' | 'update' | 'announcement'
  title: string
  thumbnail?: MicroCMSImage
}

const { date, category, badgeType, title, thumbnail } = Astro.props

const badgeColors = {
  release: 'bg-[#e3f2fd] text-[#1565c0]',
  event: 'bg-[#e0f2f1] text-[#00897b]',
  media: 'bg-[#f3e5f5] text-[#7b1fa2]',
  award: 'bg-[#fff8e1] text-[#f57c00]',
  update: 'bg-[#e8f5e9] text-[#2e7d32]',
  announcement: 'bg-[#e3f2fd] text-[#1976d2]',
}
---

<header class="pt-28 md:pt-36 pb-8 md:pb-12 px-6 md:px-12">
  <div class="max-w-[800px] mx-auto">
    <a
      href="/news"
      class="inline-flex items-center gap-2 text-[0.8125rem] text-noto-text-muted no-underline mb-8 transition-colors duration-200 hover:text-noto-accent group"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="transition-transform duration-200 group-hover:-translate-x-1"
      >
        <path d="M19 12H5M12 19l-7-7 7-7" />
      </svg>
      お知らせ一覧に戻る
    </a>

    <div class="flex items-center gap-4 mb-6">
      <span class="text-[0.8125rem] text-noto-text-muted tracking-wider">
        {date}
      </span>
      <span
        class:list={[
          'px-3 py-1 text-[0.6875rem] font-medium rounded tracking-wide',
          badgeColors[badgeType],
        ]}
      >
        {category}
      </span>
    </div>

    <h1
      class="font-serif text-[clamp(1.375rem,4vw,2.5rem)] font-medium leading-snug"
    >
      {title}
    </h1>

    {thumbnail && (
      <div class="mt-8 rounded-lg overflow-hidden">
        <img
          src={`${thumbnail.url}?fm=webp&w=1200`}
          alt={title}
          class="w-full h-auto block"
          decoding="async"
        />
      </div>
    )}
  </div>
</header>
