---
export interface InfoItem {
  label: string
  value: string
  icon: string
  isLink?: boolean
}

export interface Props {
  items: InfoItem[]
}

const { items } = Astro.props
---

<div class="border-t border-noto-border mb-12">
  {
    items.map((item) => (
      <div class="flex flex-col md:flex-row py-5 border-b border-noto-border gap-2 md:gap-0">
        <span class="flex items-center gap-2 md:w-[120px] shrink-0 text-[0.8125rem] font-medium text-noto-text-muted">
          <span class="opacity-60" set:html={item.icon} />
          {item.label}
        </span>
        {item.isLink ? (
          <a href={item.value} target="_blank" rel="noopener noreferrer" class="text-[0.9375rem] text-noto-text-muted underline break-all">{item.value}</a>
        ) : (
          <span class="text-[0.9375rem] text-noto-text whitespace-pre-line">{item.value}</span>
        )}
      </div>
    ))
  }
</div>
