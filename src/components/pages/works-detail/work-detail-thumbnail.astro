---
import { Image } from 'astro:assets'

export interface Props {
  src: string
  alt: string
  tags: string[]
}

const { src, alt, tags } = Astro.props
---

<div class="my-10 md:my-14 px-6 md:px-12">
  <div class="max-w-[1000px] mx-auto relative">
    <Image
      src={src}
      alt={alt}
      width={1200}
      height={600}
      class="w-full rounded-xl shadow-lg"
    />
    <!-- Tech Tags Overlay -->
    <div
      class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2 md:bottom-6 md:left-6"
    >
      {
        tags.map((tag) => (
          <span class="px-3 py-1.5 bg-black/60 backdrop-blur-sm text-white text-[0.6875rem] font-medium rounded tracking-wide">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</div>
