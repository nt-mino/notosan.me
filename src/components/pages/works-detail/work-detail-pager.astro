---
export interface Props {
  prev?: { id: string; title: string }
}

const { prev } = Astro.props
---

{
  prev && (
    <div class="px-6 md:px-12">
      <div class="max-w-[700px] mx-auto border-t border-noto-border pt-8 pb-4">
        <a
          href={`/works/${prev.id}`}
          class="group inline-flex items-center gap-3 text-noto-text-muted transition-colors duration-200 hover:text-noto-accent"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="shrink-0 transition-transform duration-200 group-hover:-translate-x-1"
          >
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          <div class="min-w-0">
            <span class="block text-[0.6875rem] font-semibold tracking-[0.05em] uppercase">
              Prev
            </span>
            <p class="text-[0.8125rem] font-medium text-noto-text truncate">
              {prev.title}
            </p>
          </div>
        </a>
      </div>
    </div>
  )
}
