---
export interface Props {
  class?: string
}

const { class: className } = Astro.props

const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/#works', label: 'Works' },
  { href: '/#articles', label: 'Articles' },
  { href: '/#news', label: 'News' },
  { href: '/contact', label: 'Contact' },
]
---

<nav class:list={["fixed top-0 left-0 right-0 z-50 px-6 py-6 md:px-12 flex justify-between items-center", className]}>
    <a href="/" class="font-serif text-[0.9375rem] font-medium tracking-wider">noto.</a>
    <ul class="hidden md:flex gap-8 list-none">
        {
            navLinks.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class="text-noto-text-muted text-[0.8125rem] no-underline transition-colors duration-200 hover:text-noto-text"
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>
