---
export interface Props {
  label: string
  title: string
  description: string
  bgText: string
  note?: string
  maxWidth?: 'default' | 'narrow'
}

const {
  label,
  title,
  description,
  bgText,
  note,
  maxWidth = 'default',
} = Astro.props

const maxWidthClass = maxWidth === 'narrow' ? 'max-w-[900px]' : 'max-w-[1100px]'
---

<header class:list={['pt-36 md:pt-48 pb-12 md:pb-20 px-6 md:px-12 mx-auto relative', maxWidthClass]}>
  <!-- Background text -->
  <div
    class="absolute top-20 md:top-24 left-0 font-serif text-[4rem] md:text-[clamp(6rem,15vw,12rem)] font-semibold text-noto-border opacity-30 tracking-tight leading-none pointer-events-none select-none"
    aria-hidden="true"
  >
    {bgText}
  </div>

  <!-- Content -->
  <div class="relative z-10">
    <div class="inline-flex items-center gap-4 text-[0.6875rem] text-noto-accent tracking-[0.2em] font-medium mb-6 before:content-[''] before:w-10 before:h-px before:bg-noto-accent">
      {label}
    </div>
    <h1 class="font-serif text-[clamp(2.5rem,5vw,3.5rem)] font-medium mb-6 tracking-wide">
      {title}
    </h1>
    <p class="text-base text-noto-text-muted max-w-[500px] leading-relaxed">
      {description}
    </p>
    {note && <p class="text-xs text-noto-text-muted mt-6">{note}</p>}
  </div>
</header>
