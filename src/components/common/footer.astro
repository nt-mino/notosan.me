---
interface Props {
  class?: string
}

const { class: className } = Astro.props

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '/works', label: 'Works' },
  { href: '/articles', label: 'Articles' },
  { href: '/news', label: 'News' },
  { href: '/contact', label: 'Contact' },
]

const socialLinks = [
  {
    href: '#',
    label: 'GitHub',
    icon: `<svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    href: '#',
    label: 'X (Twitter)',
    icon: `<svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    href: '#',
    label: 'Zenn',
    icon: `<svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12.586 2.586a2 2 0 0 0-2.172 0L3 8l9 6 9-6-7.414-5.414zM21 10.236l-9 6-9-6V18a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7.764z"/></svg>`,
  },
]
---

<footer class:list={["py-16 px-6 md:px-12 bg-noto-text text-white", className]}>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 max-w-[900px] mx-auto text-center md:text-left">
        <!-- Brand -->
        <div class="flex flex-col items-center md:items-start gap-2">
            <span class="font-serif text-lg font-medium mb-2">noto.</span>
            <p class="text-xs text-white/50 leading-relaxed">
                「なぜつくるのか」を大切に、本当に必要とされるものをつくる。<br />
                一人でも多くの人に届けるために、今日もコードを書いています。
            </p>
            <span class="text-[0.6875rem] text-white/40 mt-4">© 2024 noto.</span>
        </div>

        <!-- Navigation -->
        <div class="flex flex-col items-center md:items-start gap-3">
            <span class="text-[0.6875rem] font-semibold text-white/50 tracking-[0.1em] uppercase mb-2">Menu</span>
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="text-[0.8125rem] text-white/70 no-underline transition-colors duration-200 hover:text-white"
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>

        <!-- Social -->
        <div class="flex flex-col items-center md:items-start gap-3">
            <span class="text-[0.6875rem] font-semibold text-white/50 tracking-[0.1em] uppercase mb-2">Social</span>
            {
                socialLinks.map((link) => (
                    <a
                        href={link.href}
                        class="inline-flex items-center gap-2 text-[0.8125rem] text-white/70 no-underline transition-colors duration-200 hover:text-white"
                    >
                        <Fragment set:html={link.icon} />
                        {link.label}
                    </a>
                ))
            }
        </div>
    </div>
</footer>
