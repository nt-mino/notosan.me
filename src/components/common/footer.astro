---
interface Props {
  class?: string
}

const { class: className } = Astro.props

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '/works', label: 'Works' },
  { href: '/articles', label: 'Articles' },
  { href: '/news', label: 'News' },
  { href: '/contact', label: 'Contact' },
]

const socialLinks = [
  { href: '#', label: 'GitHub', icon: '/icons/github.svg' },
  { href: '#', label: 'X', icon: '/icons/x.svg' },
  { href: '#', label: 'Zenn', icon: '/icons/zenn.svg' },
  { href: '#', label: 'Wantedly', icon: '/icons/wantedly.svg' },
  { href: '#', label: 'YOUTRUST', icon: '/icons/youtrust.svg' },
  { href: '#', label: 'LAPRAS', icon: '/icons/lapras.svg' },
]
---

<footer class:list={["py-16 px-6 md:px-12 bg-noto-text text-white", className]}>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 max-w-[900px] mx-auto text-center md:text-left">
        <!-- Brand -->
        <div class="flex flex-col items-center md:items-start gap-2">
            <span class="font-serif text-lg font-medium mb-2">noto.</span>
            <p class="text-xs text-white/50 leading-relaxed">
                「なぜつくるのか」を大切に、本当に必要とされるものをつくる。<br />
                一人でも多くの人に届けるために、今日もコードを書いています。
            </p>
            <span class="text-[0.6875rem] text-white/40 mt-4">© 2024 noto.</span>
        </div>

        <!-- Navigation -->
        <div class="flex flex-col items-center md:items-start gap-3">
            <span class="text-[0.6875rem] font-semibold text-white/50 tracking-[0.1em] uppercase mb-2">Menu</span>
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="text-[0.8125rem] text-white/70 no-underline transition-colors duration-200 hover:text-white"
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>

        <!-- Social -->
        <div class="flex flex-col items-center md:items-start gap-3">
            <span class="text-[0.6875rem] font-semibold text-white/50 tracking-[0.1em] uppercase mb-2">Social</span>
            {
                socialLinks.map((link) => (
                    <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group inline-flex items-center gap-2 text-[0.8125rem] text-white/70 no-underline transition-colors duration-200 hover:text-white"
                    >
                        <img src={link.icon} alt="" class="w-4 h-4 invert opacity-70 transition-opacity duration-200 group-hover:opacity-100" />
                        {link.label}
                    </a>
                ))
            }
        </div>
    </div>
</footer>
