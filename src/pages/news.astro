---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import PageHeader from '@/components/common/page-header.astro'
import NewsItem from '@/components/pages/news/news-item.astro'
import NewsList from '@/components/pages/news/news-list.astro'
import Layout from '@/layouts/Layout.astro'
import { getNewsList } from '@/lib/microcms/api/news'
import { NEWS_CATEGORIES, type NewsCategory } from '@/lib/microcms/types/news'
import { formatDate } from '@/utils/format'

const { contents } = await getNewsList()

// カテゴリーからbadgeTypeへのマッピング
const categoryToBadgeType: Record<
  NewsCategory,
  'release' | 'event' | 'media' | 'award' | 'update'
> = {
  [NEWS_CATEGORIES.CAREER]: 'update',
  [NEWS_CATEGORIES.CERTIFICATION]: 'award',
  [NEWS_CATEGORIES.EVENT]: 'event',
  [NEWS_CATEGORIES.RELEASE]: 'release',
  [NEWS_CATEGORIES.MEDIA]: 'media',
  [NEWS_CATEGORIES.ANNOUNCEMENT]: 'update',
}

const newsItems = contents.map((news) => ({
  href: `/news/${news.id}`,
  date: formatDate(news.date),
  badge: news.category,
  badgeType: categoryToBadgeType[news.category],
  text: news.title,
}))
---

<Layout
  title="noto. - news"
  description="能戸成琉のお知らせ一覧。登壇情報、OSSリリース、メディア掲載、受賞歴など最新情報をお届けします。"
  keywords="お知らせ,登壇,カンファレンス,OSS,リリース,メディア"
>
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <PageHeader
    label="NEWS"
    title="お知らせ一覧"
    description="登壇情報やリリース情報など、最新のお知らせです。"
    bgText="News"
    maxWidth="narrow"
  />

  <main class="px-6 md:px-12 pb-24">
    <NewsList>
      {newsItems.map((item) => <NewsItem {...item} />)}
    </NewsList>
  </main>

  <Footer />
</Layout>
