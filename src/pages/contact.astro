---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import PageHeader from '@/components/common/page-header.astro'
import ContactForm from '@/components/pages/contact/contact-form'
import Layout from '@/layouts/Layout.astro'
---

<Layout
  title="noto. contact"
  description="お仕事のご依頼・ご相談など、お気軽にお問い合わせください。新規開発、技術顧問、講演など幅広く対応しています。"
  keywords="問い合わせ,ご依頼,ご相談,新規開発,技術顧問,能戸成琉"
>
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <PageHeader
    label="CONTACT"
    title="お問い合わせ"
    description="お仕事のご依頼・ご相談など、お気軽にお問い合わせください。新規開発、技術顧問、講演など幅広く対応しています。通常2〜3営業日以内にご返信いたします。"
    bgText="Contact"
    maxWidth="narrow"
  />

  <main class="px-6 md:px-12 pb-24">
    <div class="max-w-[700px] mx-auto">
      <ContactForm client:load />
    </div>
  </main>

  <Footer />
</Layout>
