---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import PageHeader from '@/components/common/page-header.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout title="noto. | Contact">
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <PageHeader
    label="CONTACT"
    title="お問い合わせ"
    description="お仕事のご依頼・ご相談など、お気軽にお問い合わせください。新規開発、技術顧問、講演など幅広く対応しています。通常2〜3営業日以内にご返信いたします。"
    bgText="Contact"
    maxWidth="narrow"
  />

  <main class="px-6 md:px-12 pb-24">
    <div class="max-w-[700px] mx-auto">
      <form class="bg-white border border-noto-border rounded-xl p-6 md:p-10">
        <!-- お名前 -->
        <div class="mb-6">
          <label class="block text-[0.8125rem] font-medium mb-2 text-noto-text">
            お名前<span class="text-red-500 ml-1 text-xs">*</span>
          </label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input
              type="text"
              name="last_name"
              placeholder="姓"
              required
              class="w-full px-4 py-3.5 text-[0.9375rem] border border-noto-border rounded-md bg-noto-bg text-noto-text placeholder:text-noto-text-muted transition-all duration-200 focus:outline-none focus:border-noto-accent focus:ring-[3px] focus:ring-noto-accent/10"
            />
            <input
              type="text"
              name="first_name"
              placeholder="名"
              required
              class="w-full px-4 py-3.5 text-[0.9375rem] border border-noto-border rounded-md bg-noto-bg text-noto-text placeholder:text-noto-text-muted transition-all duration-200 focus:outline-none focus:border-noto-accent focus:ring-[3px] focus:ring-noto-accent/10"
            />
          </div>
        </div>

        <!-- メールアドレス -->
        <div class="mb-6">
          <label class="block text-[0.8125rem] font-medium mb-2 text-noto-text" for="email">
            メールアドレス<span class="text-red-500 ml-1 text-xs">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="example@email.com"
            required
            class="w-full px-4 py-3.5 text-[0.9375rem] border border-noto-border rounded-md bg-noto-bg text-noto-text placeholder:text-noto-text-muted transition-all duration-200 focus:outline-none focus:border-noto-accent focus:ring-[3px] focus:ring-noto-accent/10"
          />
        </div>

        <!-- 会社名 -->
        <div class="mb-6">
          <label class="block text-[0.8125rem] font-medium mb-2 text-noto-text" for="company">
            会社名<span class="text-red-500 ml-1 text-xs">*</span>
          </label>
          <input
            type="text"
            id="company"
            name="company"
            placeholder="株式会社〇〇"
            required
            class="w-full px-4 py-3.5 text-[0.9375rem] border border-noto-border rounded-md bg-noto-bg text-noto-text placeholder:text-noto-text-muted transition-all duration-200 focus:outline-none focus:border-noto-accent focus:ring-[3px] focus:ring-noto-accent/10"
          />
        </div>

        <!-- 種別 -->
        <div class="mb-6">
          <label class="block text-[0.8125rem] font-medium mb-2 text-noto-text" for="category">
            種別<span class="text-red-500 ml-1 text-xs">*</span>
          </label>
          <div class="relative">
            <select
              id="category"
              name="category"
              required
              class="w-full px-4 py-3.5 text-[0.9375rem] border border-noto-border rounded-md bg-noto-bg text-noto-text appearance-none cursor-pointer pr-10 transition-all duration-200 focus:outline-none focus:border-noto-accent focus:ring-[3px] focus:ring-noto-accent/10"
            >
              <option value="" disabled selected>選択してください</option>
              <option value="product">新規・既存プロダクト開発の相談</option>
              <option value="support">技術支援</option>
              <option value="advisor">技術顧問・アドバイザリー</option>
              <option value="speaking">講演・登壇依頼</option>
              <option value="interview">取材・インタビュー</option>
              <option value="other">その他</option>
            </select>
            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M6 8L1 3h10z" fill="#737373" />
              </svg>
            </div>
          </div>
        </div>

        <!-- お問い合わせ内容 -->
        <div class="mb-8">
          <label class="block text-[0.8125rem] font-medium mb-2 text-noto-text" for="message">
            お問い合わせ内容<span class="text-red-500 ml-1 text-xs">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            placeholder="ご依頼内容やご相談内容をご記入ください"
            required
            class="w-full px-4 py-3.5 text-[0.9375rem] border border-noto-border rounded-md bg-noto-bg text-noto-text placeholder:text-noto-text-muted min-h-[180px] resize-y leading-relaxed transition-all duration-200 focus:outline-none focus:border-noto-accent focus:ring-[3px] focus:ring-noto-accent/10"
          ></textarea>
        </div>

        <!-- 送信ボタン -->
        <button
          type="submit"
          class="w-full inline-flex items-center justify-center gap-2 px-8 py-4 text-[0.9375rem] font-medium text-white bg-noto-text rounded-md transition-all duration-200 hover:bg-noto-accent active:scale-[0.98]"
        >
          送信する
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>

        <!-- 注意書き -->
        <p class="mt-6 pt-6 border-t border-noto-border text-xs text-noto-text-muted leading-relaxed">
          ※ 内容によってはご返信できない場合がございます。あらかじめご了承ください。<br />
          ※ 個人情報は本お問い合わせへの対応以外には使用いたしません。
        </p>
      </form>
    </div>
  </main>

  <Footer />
</Layout>
