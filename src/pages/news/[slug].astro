---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import NewsDetailBody from '@/components/pages/news-detail/news-detail-body.astro'
import NewsDetailHeader from '@/components/pages/news-detail/news-detail-header.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllNewsIds, getNews } from '@/lib/microcms/api/news'
import { NEWS_CATEGORIES, type NewsCategory } from '@/lib/microcms/types/news'
import { formatDate } from '@/utils/format'

export async function getStaticPaths() {
  const ids = await getAllNewsIds()
  return ids.map((id) => ({
    params: { slug: id },
  }))
}

const { slug } = Astro.params
const news = await getNews(slug)

// カテゴリーからbadgeTypeへのマッピング
const categoryToBadgeType: Record<
  NewsCategory,
  'release' | 'event' | 'media' | 'award' | 'update'
> = {
  [NEWS_CATEGORIES.CAREER]: 'update',
  [NEWS_CATEGORIES.CERTIFICATION]: 'award',
  [NEWS_CATEGORIES.EVENT]: 'event',
  [NEWS_CATEGORIES.RELEASE]: 'release',
  [NEWS_CATEGORIES.MEDIA]: 'media',
  [NEWS_CATEGORIES.ANNOUNCEMENT]: 'update',
}

const badgeType = categoryToBadgeType[news.category]
---

<Layout
  title={`${news.title} | noto.`}
  description={news.title}
  keywords="お知らせ,ニュース,能戸成琉"
  ogType="article"
>
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <article>
    <NewsDetailHeader
      date={formatDate(news.date)}
      category={news.category}
      badgeType={badgeType}
      title={news.title}
      thumbnail={news.thumbnail}
    />
    <NewsDetailBody body={news.body} />
  </article>

  <Footer />
</Layout>
