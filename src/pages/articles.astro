---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import PageHeader from '@/components/common/page-header.astro'
import ArticleCard from '@/components/pages/articles/article-card.astro'
import ArticlesGrid from '@/components/pages/articles/articles-grid.astro'
import Layout from '@/layouts/Layout.astro'
import { getArticles } from '@/lib/microcms/api/articles'
import { formatDate } from '@/utils/format'

const { contents } = await getArticles({ limit: 50 })

const articles = contents.map((article) => ({
  href: article.zennUrl,
  category: article.category,
  thumbnail: article.thumbnail,
  date: formatDate(article.date),
  title: article.title,
  excerpt: article.description,
  isExternal: true,
}))
---

<Layout
  title="noto. articles"
  description="能戸成琉の技術記事一覧。フロントエンドの技術選定・比較や分析、開発ストーリーを中心に発信。"
  keywords="技術記事,ブログ,TypeScript,React,マイクロサービス,設計パターン,ベストプラクティス"
>
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <PageHeader
    label="ARTICLES"
    title="執筆一覧"
    description="技術ブログやZennで執筆した記事の一覧です。フロントエンドの技術選定・比較や分析、開発ストーリーを中心に発信しています。"
    bgText="Articles"
  />

  <main class="px-6 md:px-12 pb-24">
    <ArticlesGrid>
      {articles.map((article) => <ArticleCard {...article} />)}
    </ArticlesGrid>
  </main>

  <Footer />
</Layout>
