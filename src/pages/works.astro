---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import PageHeader from '@/components/common/page-header.astro'
import WorkCard from '@/components/pages/works/work-card.astro'
import WorksGrid from '@/components/pages/works/works-grid.astro'
import Layout from '@/layouts/Layout.astro'
import { getWorks } from '@/lib/microcms/api/works'

const { contents } = await getWorks()

const works = contents.map((work) => ({
  href: `/works/${work.id}`,
  thumbnail: work.thumbnail.url,
  alt: work.title,
  company: work.company,
  title: work.title,
  description: work.description,
}))
---

<Layout
  title="noto. works"
  description="能戸成琉の実績一覧。AIチャットプラットフォーム、決済システム刷新、OSSライブラリ開発など、バックエンドからフロントエンドまで幅広いプロジェクトを担当。"
  keywords="実績,ポートフォリオ,開発事例,バックエンド,フロントエンド,マイクロサービス,OSS"
>
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <PageHeader
    label="WORKS"
    title="実績一覧"
    description="これまで携わったプロジェクトの一覧です。バックエンドからフロントエンドまで幅広く担当しています。"
    bgText="Works"

  />

  <main class="px-6 md:px-12 pb-24">
    <WorksGrid>
      {works.map((work) => <WorkCard {...work} />)}
    </WorksGrid>
  </main>

  <Footer />
</Layout>
