---
import Footer from '@/components/common/footer.astro'
import Navigation from '@/components/common/navigation.astro'
import WorkDetailBody from '@/components/pages/works-detail/work-detail-body.astro'
import WorkDetailCta from '@/components/pages/works-detail/work-detail-cta.astro'
import WorkDetailHeader from '@/components/pages/works-detail/work-detail-header.astro'
import WorkDetailInfo from '@/components/pages/works-detail/work-detail-info.astro'
import WorkDetailThumbnail from '@/components/pages/works-detail/work-detail-thumbnail.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllWorkIds, getWork } from '@/lib/microcms/api/works'

export async function getStaticPaths() {
  const ids = await getAllWorkIds()
  return ids.map((id) => ({
    params: { slug: id },
  }))
}

const { slug } = Astro.params
const work = await getWork(slug)

const infoItems = [
  {
    label: '企業名',
    value: work.company,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M3 7v1a3 3 0 0 0 6 0V7m0 1a3 3 0 0 0 6 0V7m0 1a3 3 0 0 0 6 0V7H3l2-4h14l2 4M5 21V10.85M19 21V10.85M9 21v-4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4"></path></svg>',
  },
  {
    label: '役割',
    value: work.position,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>',
  },
  {
    label: '業界',
    value: work.business,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>',
  },
  {
    label: 'フェーズ',
    value: work.phase,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>',
  },
  {
    label: '技術',
    value: work.tech,
    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>',
  },
]
---

<Layout
  title={work.title}
  description={work.description}
  keywords={`実績,${work.tech.replace(/, /g, ',')},${work.phase}`}
  ogImage={work.thumbnail.url}
  ogType="article"
>
  <Navigation class="bg-noto-bg/90 backdrop-blur-sm" />

  <article>
    <WorkDetailHeader
      company={work.company}
      title={work.title}
      description={work.description}
    />

    <WorkDetailThumbnail
      src={work.thumbnail.url}
      alt={work.title}
    />

    <div class="px-6 md:px-12 pb-12">
      <div class="max-w-[700px] mx-auto">
        <WorkDetailInfo items={infoItems} />
        <WorkDetailBody body={work.body} />
      </div>
    </div>

    <WorkDetailCta />
  </article>

  <Footer />
</Layout>
